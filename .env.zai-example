# Z.AI API Configuration
# Copy these lines into your .env file to switch NanoClaw to use Z.AI (GLM-5.1)
# instead of the Anthropic Claude API.
#
# Get your API key from: https://z.ai/manage-apikey/apikey-list
#
# Steps:
#   1. Add the lines below to your .env file (fill in your key)
#   2. Update nanoclaw.settings.json: { "model": "glm-5.1" }
#   3. Delete the existing .claude/settings.json in the group session dir so
#      API_TIMEOUT_MS is picked up on next container start:
#      rm data/sessions/discord_main/.claude/settings.json
#   4. Restart NanoClaw: npm run restart (or docker compose restart)
#
# To revert to Claude: remove these lines from .env, restore nanoclaw.settings.json,
# delete settings.json again, and restart.

ZAI_API_KEY=<your_z.ai_api_key_here>
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
API_TIMEOUT_MS=300000
